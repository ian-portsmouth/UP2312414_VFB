@model List<FoodBankApp.Models.StaffOrderListItem>
@{
    ViewData["Title"] = "Orders";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Orders</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-dark" asp-controller="Stock" asp-action="Index">Stock</a>
        </div>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <input name="code" value="@(ViewBag.FilterCode ?? "")" class="form-control" placeholder="Filter by Order Code (e.g., 01)" />
        </div>
        <div class="col-auto">
            <button class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (TempData["Flash"] is string flash)
    {
        <div class="alert alert-success">@flash</div>
    }

    <div class="table-responsive">
    <table class="table table-striped align-middle bg-white">
        <thead>
            <tr>
                <th>Date</th>
                <th>Order Code</th>
                <th>Contact</th>
                <th>Status</th>
                <th style="width:220px"></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var o in Model)
        {
            var isCompleted = o.Status?.Equals("Completed", StringComparison.OrdinalIgnoreCase) ?? false;
            <tr>
                <td>@o.DateCreated.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td><strong>@o.OrderCode</strong></td>
                <td>@o.ContactName</td>
                <td>
                    @if (isCompleted)
                    {
                        <span class="badge bg-success">Completed</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">@o.Status</span>
                    }
                </td>
                <td class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@o.OrderId" class="btn btn-sm btn-outline-primary">View</a>

                    @if (!isCompleted)
                    {
                        <form asp-action="Complete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@o.OrderId" />
                            <button class="btn btn-sm btn-success">Complete</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
</div>
