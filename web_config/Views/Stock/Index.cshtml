@model FoodBankApp.Models.StockIndexViewModel
@{
    ViewData["Title"] = "Stock Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Stock Management</h3>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" asp-action="Create">Add New Item</a>
            <form asp-action="SeedBasics" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-secondary" type="submit">Add Starter Items</button>
            </form>
            <a class="btn btn-outline-dark" asp-controller="StaffOrders" asp-action="Index">Orders</a>
        </div>
    </div>

    @if (TempData["Flash"] is string flash)
    {
        <div class="alert alert-success">@flash</div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-12 col-md-5">
            <input name="q" value="@(Model.Search ?? "")" class="form-control" placeholder="Search item name..." />
        </div>
        <div class="col-12 col-md-3">
            <select class="form-select" name="category">
                <option value="">All categories</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c" selected="@(string.Equals(Model.Category, c, StringComparison.OrdinalIgnoreCase))">@c</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2 d-flex align-items-center">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="showInactive" name="showInactive" value="true" @(Model.ShowInactive ? "checked" : "")>
                <label class="form-check-label" for="showInactive">Show inactive</label>
            </div>
        </div>
        <div class="col-12 col-md-2 d-grid">
            <button class="btn btn-primary">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped align-middle bg-white">
            <thead>
                <tr>
                    <th style="width:72px"></th>
                    <th>Item</th>
                    <th>Category</th>
                    <th style="width:120px">Stock</th>
                    <th style="width:120px">Status</th>
                    <th style="width:260px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.Items)
                {
                    <tr>
                        <td>
                            <img src="@Url.Content(it.ImagePath ?? "/images/items/default.png")"
                                 alt="@it.ItemName"
                                 class="rounded-3 border"
                                 style="width:56px;height:56px;object-fit:cover;" />
                        </td>
                        <td>
                            <div class="fw-semibold">@it.ItemName</div>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(it.Category) ? "—" : it.Category)</td>
                        <td>@it.StockQuantity</td>
                        <td>
                            @if (it.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="d-flex gap-2">
                            <a class="btn btn-sm btn-outline-success" asp-action="AddStock" asp-route-id="@it.ItemId">Add Stock</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@it.ItemId">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
