@model FoodBankApp.Models.AddStockViewModel
@{
    ViewData["Title"] = "Add Stock";
}

<div class="container mt-4" style="max-width: 720px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Add Stock</h3>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-1">@Model.ItemName</h5>
            <p class="text-muted mb-0">Current stock: <strong>@Model.CurrentStock</strong></p>
        </div>
    </div>

    <form asp-action="AddStock" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ItemId" />
        <input type="hidden" asp-for="ItemName" />
        <input type="hidden" asp-for="CurrentStock" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="AddAmount" class="form-label"></label>
            <input asp-for="AddAmount" class="form-control" type="number" min="1" />
            <span asp-validation-for="AddAmount" class="text-danger"></span>
        </div>

        <div class="d-grid d-md-flex gap-2">
            <button class="btn btn-success" type="submit">Add</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
