@model FoodBankApp.Models.PublicOrderViewModel

@{
    ViewData["Title"] = "Place an Order";
}

<div class="row mb-4">
    <div class="col-lg-8">
        <h2 class="mb-1">Place an Order</h2>
        <p class="text-muted mb-0">
            Tap on the cards below to add items to your order. Use + / – to adjust quantity you want to order.
        </p>
    </div>
</div>

<form asp-action="Create" method="post">
    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="ContactName" class="form-label"></label>
            <input asp-for="ContactName" class="form-control" />
            <span asp-validation-for="ContactName" class="text-danger"></span>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        @for (var i = 0; i < Model.Lines.Count; i++)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 food-item-card"
                     data-index="@i"
                     data-max="@Model.Lines[i].Available">
                    <div class="ratio ratio-4x3">
                        <img src="@Url.Content(Model.Lines[i].ImagePath ?? "/images/items/default.png")"
                             class="card-img-top object-fit-cover"
                             alt="@Model.Lines[i].ItemName" />
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title mb-1">@Model.Lines[i].ItemName</h6>
                        @if (!string.IsNullOrEmpty(Model.Lines[i].Category))
                        {
                            <p class="text-muted small mb-1">@Model.Lines[i].Category</p>
                        }
                        <p class="small text-muted mb-2">
                            In stock: @Model.Lines[i].Available
                        </p>

                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button"
                                        class="btn btn-outline-secondary js-qty-minus"
                                        data-index="@i">-</button>
                                <span class="px-2 quantity-display"
                                      id="qty-display-@i">
                                    @Model.Lines[i].Quantity
                                </span>
                                <button type="button"
                                        class="btn btn-outline-secondary js-qty-plus"
                                        data-index="@i">+</button>
                            </div>
                        </div>
                    </div>

        
                    <input type="hidden" asp-for="Lines[i].ItemId" />
                    <input type="hidden" asp-for="Lines[i].ItemName" />
                    <input type="hidden" asp-for="Lines[i].Category" />
                    <input type="hidden" asp-for="Lines[i].Available" />
                    <input type="hidden" asp-for="Lines[i].ImagePath" />
                    <input type="hidden"
                           asp-for="Lines[i].Quantity"
                           class="js-qty-input"
                           data-index="@i" />
                </div>
            </div>
        }
    </div>

    <div class="row mt-4">
        <div class="col-md-6 d-grid d-md-flex gap-2">
            <button type="submit" class="btn btn-primary">
                Submit Order
            </button>
            <button type="reset" class="btn btn-outline-secondary"
                    id="clearSelectionBtn">
                Clear Selection
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            function updateCardState(index, qty) {
                var card = document.querySelector('.food-item-card[data-index="' + index + '"]');
                var display = document.getElementById('qty-display-' + index);
                var input = document.querySelector('.js-qty-input[data-index="' + index + '"]');

                if (!card || !display || !input) return;

                display.textContent = qty;
                input.value = qty;

                if (qty > 0) {
                    card.classList.add('food-item-selected');
                } else {
                    card.classList.remove('food-item-selected');
                }
            }

            document.querySelectorAll('.js-qty-plus').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var index = this.getAttribute('data-index');
                    var card = document.querySelector('.food-item-card[data-index="' + index + '"]');
                    var max = parseInt(card.getAttribute('data-max') || '9999');

                    var input = document.querySelector('.js-qty-input[data-index="' + index + '"]');
                    var current = parseInt(input.value || '0');

                    if (current < max) {
                        updateCardState(index, current + 1);
                    }
                });
            });

            document.querySelectorAll('.js-qty-minus').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var index = this.getAttribute('data-index');
                    var input = document.querySelector('.js-qty-input[data-index="' + index + '"]');
                    var current = parseInt(input.value || '0');

                    if (current > 0) {
                        updateCardState(index, current - 1);
                    }
                });
            });

            
            document.querySelectorAll('.food-item-card').forEach(function (card) {
                card.addEventListener('click', function (e) {
                    
                    if (e.target.closest('button')) return;

                    var index = this.getAttribute('data-index');
                    var max = parseInt(this.getAttribute('data-max') || '9999');
                    var input = document.querySelector('.js-qty-input[data-index="' + index + '"]');
                    var current = parseInt(input.value || '0');

                    if (current < max) {
                        updateCardState(index, current + 1);
                    }
                });
            });

            
            var clearBtn = document.getElementById('clearSelectionBtn');
            if (clearBtn) {
                clearBtn.addEventListener('click', function () {
                    document.querySelectorAll('.js-qty-input').forEach(function (input) {
                        var index = input.getAttribute('data-index');
                        updateCardState(index, 0);
                    });
                });
            }
        })();
    </script>
}
